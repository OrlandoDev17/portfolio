---
import ContactContainer from '../components/ContactContainer.astro';
import MailIcon from '../icons/Mail.astro';
---

<footer
  id="contact"
  class="flex flex-col justify-center items-center px-8 md:px-16 xl:px-32 2xl:px-64 py-1 gap-12 dark:bg-zinc-800 dark:text-white"
>
  <div class="flex flex-col items-center justify-center gap-4">
    <h2 class="flex items-center gap-2 text-4xl font-semibold">
      <MailIcon class="text-violet-500 size-12" />
      Contacto
    </h2>
    <p class="max-w-3xl text-center text-lg text-gray-700 dark:text-gray-300">
      ¿Tienes un proyecto en mente? ¡Hablemos y hagámoslo realidad!
    </p>
  </div>
  <div>
    <ContactContainer />
  </div>
  <div class="flex flex-col items-center justify-center gap-4 mb-4">
    <hr class="w-full text-gray-300 dark:text-gray-100" />
    <p class="text-gray-700 dark:text-gray-300 text-center">
      © 2025 Portfolio de Orlando López. Desarrollado con ❤️ usando Astro y
      Tailwind CSS
    </p>
  </div>
</footer>
