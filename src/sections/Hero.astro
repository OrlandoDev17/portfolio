---
import BriefCaseIcon from '../icons/BriefCase.astro';
import MessageIcon from '../icons/Message.astro';
import DownloadIcon from '../icons/Download.astro';
import SocialMedia from '../components/SocialMedia.astro';
---

<section
  class="flex justify-center items-center px-64 py-10 relative flex-row top-23 gap-26 dark:bg-zinc-800 mb-24"
>
  <div class="flex flex-col items-start gap-4">
    <a
      class="flex items-center gap-2 bg-green-200 text-green-900 px-3 py-1 rounded-full font-medium text-sm hover:bg-green-400 hover:scale-110 transition dark:bg-green-700 dark:text-green-200 dark:hover:bg-green-600"
      href="#"
    >
      <BriefCaseIcon class="size-6" />
      Disponible para trabajar</a
    >
    <h1 class="text-7xl font-black gradient-text">Orlando López</h1>
    <h3 class="text-4xl font-semibold text-gray-800 dark:text-white">
      Desarrollador Front-End
    </h3>
    <h4 class="text-xl text-gray-700 dark:text-gray-100">
      Ingeniero en Informática en formación
    </h4>
    <p class="text-xl text-gray-500 max-w-160 dark:text-gray-300">
      <strong class="text-blue-500"> +2 años</strong> de experiencia autodidacta
      creando experiencias web modernas e intuitivas
    </p>
    <div class="flex items-center gap-6">
      <a
        class="flex items-center gap-3 py-2 px-4 rounded-lg text-lg tracking-wide bg-gradient-to-r from-blue-500 via-violet-600 to-violet-700 text-white hover:brightness-125 hover:-translate-y-1 transition"
        href="https://wa.me/+584242860846"
        target="_blank"
        rel="noopener noreferrer"
      >
        <MessageIcon />
        Contactame
      </a>
      <a
        class="flex items-center gap-3 py-2 px-4 rounded-lg text-lg tracking-wide border-2 border-blue-500 text-blue-500 hover:bg-blue-500 hover:text-white hover:-translate-y-1 transition"
        href="./assets/CV.pdf"
        download
      >
        <DownloadIcon />
        Descargar CV
      </a>
    </div>
    <SocialMedia />
  </div>
  <aside>
    <img
      class="size-86 rounded-full p-4 border-4 border-blue-500"
      src="./assets/photo.png"
      alt="Fotografia de Orlando López"
    />
  </aside>
</section>
