---
import BriefCaseIcon from '../icons/BriefCase.astro';
import MessageIcon from '../icons/Message.astro';
import DownloadIcon from '../icons/Download.astro';
import SocialMedia from '../components/SocialMedia.astro';

import AnimateContainer from '../components/AnimateContainer.astro';
import GradientButton from '../components/GradientButton.astro';
import BorderButton from '../components/BorderButton.astro';
---

<section
  class="flex flex-col md:flex-row justify-center items-center px-4 md:px-16 xl:px-32 2xl:px-64 py-10 pb-18 relative top-23 gap-2 xl:gap-12 2xl:gap-26 dark:bg-zinc-800 mb-24 h-[90vh] md:h-[65vh]"
>
  <AnimateContainer>
    <div class="a-slide-in-left opacity-0 flex flex-col items-start gap-4">
      <a
        class="flex items-center gap-2 bg-green-200 text-green-900 px-3 py-1 rounded-full font-medium text-sm hover:bg-green-400 hover:scale-110 transition dark:bg-green-700 dark:text-green-200 dark:hover:bg-green-600"
        href="https://wa.me/+584242860846"
      >
        <BriefCaseIcon class="size-6" />
        Disponible para trabajar</a
      >
      <h1
        class="text-6xl md:text-7xl font-black gradient-text max-w-80 md:max-w-full"
      >
        Orlando López
      </h1>
      <h3
        class="text-2xl md:text-4xl font-semibold text-gray-800 dark:text-white max-w-80 lg:max-w-full"
      >
        Desarrollador Front-End
      </h3>
      <h4 class="text-lg md:text-xl text-gray-700 dark:text-gray-100">
        Ingeniero en Informática en formación
      </h4>
      <p class="text-lg md:text-xl text-gray-500 max-w-160 dark:text-gray-300">
        <strong class="text-blue-500"> +2 años</strong> de experiencia autodidacta
        creando experiencias web modernas e intuitivas
      </p>
      <div class="flex items-center gap-2 md:gap-6">
        <GradientButton href="https://wa.me/+584242860846">
          <MessageIcon />
          Contactame
        </GradientButton>
        <BorderButton href="./assets/CV.pdf" download>
          <DownloadIcon />
          Descargar CV
        </BorderButton>
      </div>
      <SocialMedia />
    </div>
  </AnimateContainer>
  <AnimateContainer>
    <aside class="a-slide-in-right opacity-0">
      <img
        class="size-84 lg:size-76 xl:size-84 object-cover rounded-full p-4 border-4 border-blue-500"
        src="./assets/photo.png"
        alt="Fotografia de Orlando López"
      />
    </aside>
  </AnimateContainer>
</section>
