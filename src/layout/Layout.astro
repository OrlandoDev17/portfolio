---
import Header from '../components/Header.astro';
import '../styles/global.css';
import '../styles/animations.css';
import '@fontsource-variable/montserrat';
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Open Graph -->
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="Portfolio de Orlando López | Desarrollador Front-End"
    />
    <meta
      property="og:description"
      content="Portafolio de Orlando López, Desarrollador Front-End. Descubre proyectos, habilidades y pasiones en tecnología, diseño web y desarrollo moderno. ¡Conoce más sobre mi trabajo y trayectoria!"
    />
    <meta
      property="og:url"
      content="https://orlando-lopez-portfolio.vercel.app/"
    />

    <meta property="og:image" content="./images/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Portfolio de Orlando López | Desarrollador Front-End"
    />
    <meta
      name="twitter:description"
      content="Portafolio de Orlando López, Desarrollador Front-End. Descubre proyectos, habilidades y pasiones en tecnología, diseño web y desarrollo moderno. ¡Conoce más sobre mi trabajo y trayectoria!"
    />
    <meta name="twitter:image" content="./images/og-image.png" />
    <meta name="twitter:image:width" content="1200" />
    <meta name="twitter:image:height" content="630" />
    <!-- Otros Metadatos -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <title>Portfolio de Orlando López | Desarrollador Front-End</title>
  </head>
  <body class="dark:bg-zinc-800">
    <Header />
    <slot />
  </body>
</html>

<style>
  html,
  body {
    font-family: 'Montserrat Variable', sans-serif;
    box-sizing: border-box;
    scroll-behavior: smooth;
    color: #222;
  }
</style>
