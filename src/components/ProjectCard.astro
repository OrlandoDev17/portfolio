---
import { PROJECTS } from '../consts/Consts';
import GitHubIcon from '../icons/GitHub.astro';
import RocketIcon from '../icons/Rocket.astro';
import AnimateContainer from './AnimateContainer.astro';
import BorderButton from './BorderButton.astro';
import GradientButton from './GradientButton.astro';
---

<AnimateContainer>
  <div
    class="a-scale-in-center opacity-0 grid grid-cols-1 md:grid-cols-2 gap-12"
  >
    {
      PROJECTS.map(({ title, description, image, links, tags }) => (
        <article class="flex flex-col gap-6 rounded-xl shadow-black/60 dark:shadow-gray-600 shadow-lg max-w-md hover:shadow-xl transition">
          <picture>
            <img
              class="rounded-t-xl border-b-2 border-slate-700"
              src={image}
              alt={title}
            />
          </picture>
          <div class="flex flex-col gap-4 px-6 py-2">
            <h3 class="text-xl md:text-3xl font-semibold tracking-wide mb-1">
              {title}
            </h3>
            <p class="text-pretty text-gray-600 text-sm dark:text-gray-200">
              {description}
            </p>
            <div class="flex flex-col gap-4">
              <h4 class="text-lg font-medium">Tecnologías Usadas:</h4>
              <aside class="flex items-center gap-1 flex-wrap justify-start">
                {tags?.map(({ icon: Icon, name }) => (
                  <span class="flex items-center gap-2 bg-gray-200 px-3 py-2 rounded-full text-sm font-medium dark:bg-gray-700">
                    <Icon class="size-6" />
                    {name}
                  </span>
                ))}
              </aside>
            </div>
            <div class="flex justify-between items-center py-4 w-full">
              {links?.map(({ demo, code }) => (
                <>
                  <GradientButton class="w-full" href={demo}>
                    <RocketIcon />
                    Ver Demo
                  </GradientButton>
                  <BorderButton class="w-full" href={code}>
                    <GitHubIcon />
                    Ver Código
                  </BorderButton>
                </>
              ))}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</AnimateContainer>
