---
import SocialContact from './SocialContact.astro';
import MessageIcon from '../icons/Message.astro';
import DownloadIcon from '../icons/Download.astro';
import AnimateContainer from './AnimateContainer.astro';
import GradientButton from './GradientButton.astro';
import BorderButton from './BorderButton.astro';
---

<AnimateContainer>
  <article
    class="a-slide-in-left opacity-0 flex flex-col md:flex-row items-start justify-center shadow-lg shadow-gray-600 p-8 mb-4 rounded-xl gap-12"
  >
    <div class="flex flex-col justify-center gap-6">
      <h3 class="text-2xl font-semibold">¡Conectemos!</h3>
      <p class="max-w-100 text-gray-600 text-pretty dark:text-gray-300">
        Estoy siempre abierto a nuevas oportunidades y colaboraciones. No dudes
        en contactarme para discutir tu próximo proyecto
      </p>
      <SocialContact />
    </div>
    <div class="flex flex-col justify-center gap-6">
      <h3 class="text-2xl font-semibold">¿Listo para trabajar juntos?</h3>
      <GradientButton href="https://wa.me/+584242860846">
        <MessageIcon />
        Enviar Mensaje por WhatsApp
      </GradientButton>
      <hr class="w-full text-gray-200" />
      <span class="text-sm text-gray-400"
        >O descarga mi CV para más detalles</span
      >
      <BorderButton class="justify-center" href="./assets/CV.pdf" download>
        <DownloadIcon />
        Descargar CV
      </BorderButton>
    </div>
  </article>
</AnimateContainer>
